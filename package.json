{
  "name": "watch-discord-dev-changes",
  "version": "2.0.0",
  "description": "When an update is made to Discord's Developer Change Log, the specific channel on Discord will be notified.",
  "homepage": "https://github.com/tomacheese/watch-discord-dev-changes",
  "bugs": {
    "url": "https://github.com/tomacheese/watch-discord-dev-changes/issues"
  },
  "license": "MIT",
  "author": "Tomachi <tomachi@tomacheese.com>",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:tomacheese/watch-discord-dev-changes.git"
  },
  "scripts": {
    "fix:prettier": "prettier --write src",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "lint:prettier": "prettier --check src",
    "fix": "run-z fix:prettier fix:eslint",
    "lint:tsc": "tsc",
    "test": "jest --runInBand --passWithNoTests --detectOpenHandles --forceExit",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "dev": "tsx watch ./src/main.ts",
    "start": "tsx ./src/main.ts",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.14.30",
    "@book000/node-utils": "1.24.167",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.3",
    "date-fns": "4.1.0",
    "eslint": "10.3.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.0.1",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.4.0",
    "jest-expect-message": "1.1.3",
    "prettier": "3.8.3",
    "run-z": "2.1.0",
    "ts-jest": "29.4.9",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "jest": {
    "testMatch": [
      "**/*.test.ts"
    ],
    "setupFilesAfterEnv": [
      "jest-expect-message"
    ],
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912"
}
