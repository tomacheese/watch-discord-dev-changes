{
  "name": "watch-discord-dev-changes",
  "version": "2.0.0",
  "description": "When an update is made to Discord's Developer Change Log, the specific channel on Discord will be notified.",
  "homepage": "https://github.com/tomacheese/watch-discord-dev-changes",
  "bugs": {
    "url": "https://github.com/tomacheese/watch-discord-dev-changes/issues"
  },
  "license": "MIT",
  "author": "Tomachi <tomachi@tomacheese.com>",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:tomacheese/watch-discord-dev-changes.git"
  },
  "scripts": {
    "fix:prettier": "prettier --write src",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "lint:prettier": "prettier --check src",
    "fix": "run-z fix:prettier fix:eslint",
    "lint:tsc": "tsc",
    "test": "jest --runInBand --passWithNoTests --detectOpenHandles --forceExit",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "dev": "tsx watch ./src/main.ts",
    "start": "tsx ./src/main.ts",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.15.2",
    "@book000/node-utils": "1.24.232",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.2",
    "date-fns": "4.4.0",
    "eslint": "10.4.1",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.4.2",
    "jest-expect-message": "1.1.3",
    "prettier": "3.8.4",
    "run-z": "2.1.0",
    "ts-jest": "29.4.11",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "jest": {
    "testMatch": [
      "**/*.test.ts"
    ],
    "setupFilesAfterEnv": [
      "jest-expect-message"
    ],
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
